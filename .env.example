# ========== Provider 配置 ==========
# 系统支持 4 个 Provider，按需配置 API Key 即可启用

# DeepSeek (轻量级任务：分类/提取/评估)
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# Gemini 青云中转 (重量级任务：出题/变式/分析)
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_BASE_URL="https://api.qingyuntop.top/v1"
GEMINI_MODEL="gemini-3.1-pro-preview"

# 硅基流动 SiliconFlow (可选, GLM-5 / Kimi-K2.5)
SILICONFLOW_API_KEY="your-siliconflow-api-key-here"
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"

# OpenRouter (可选, 多 Gemini 模型)
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ========== 模型池配置 ==========
# 格式: provider:model,provider:model,...（逗号分隔，按优先级排列）
# 未配置时自动回退到旧逻辑（Gemini→DeepSeek / DeepSeek / OpenRouter→DeepSeek）

# Heavy池（出题/变式 — 需要创造力+长输出）
POOL_HEAVY=gemini:gemini-3.1-pro-preview,openrouter:google/gemini-2.5-pro,siliconflow:Pro/zai-org/GLM-5,siliconflow:Pro/moonshotai/Kimi-K2.5

# Light池（推理评估/分类/提取 — 需要速度）
POOL_LIGHT=deepseek:deepseek-chat,siliconflow:Pro/moonshotai/Kimi-K2.5,openrouter:google/gemini-3-flash-preview

# Fast池（JSON修复/紧急兜底 — 最快响应）
POOL_FAST=openrouter:google/gemini-3.1-flash-lite-preview,openrouter:google/gemini-3-flash-preview,deepseek:deepseek-chat

# ========== 数据库 ==========
DATABASE_PATH="./data/learning.db"
AGENT_DATABASE_PATH="./data/agent.db"
RUNTIME_DATABASE_PATH="./data/learning_runtime.db"
REVIEW_DATABASE_PATH="./data/wrong_answer_review.db"

# ========== OpenViking（可选外部上下文服务） ==========
# 先单独启动 OpenViking Server，再开启下面开关
OPENVIKING_ENABLED=false
OPENVIKING_URL="http://localhost:1933"
OPENVIKING_API_KEY=""
OPENVIKING_AGENT_ID="true-learning-system"
OPENVIKING_TIMEOUT=15
OPENVIKING_SEARCH_LIMIT=5
OPENVIKING_TARGET_URI=""
OPENVIKING_SYNC_ENABLED=true
OPENVIKING_SYNC_EXPORT_DIR="./data/openviking_exports"
OPENVIKING_SYNC_ROOT_URI="viking://resources/true-learning-system"
OPENVIKING_SYNC_WAIT=false
OPENVIKING_SYNC_BATCH_SIZE=50

# ========== 功能开关 ==========
# 强制 Heavy 池必须用重量级模型（默认池中不添加 DeepSeek 回退）
STRICT_HEAVY_MODEL=true

# 缓存系统
QUIZ_CACHE_ENABLED=true
QUIZ_CACHE_TTL_SECONDS=3600

# 主题一致性校验
QUIZ_TOPIC_CHECK_ENABLED=true
QUIZ_TOPIC_OVERLAP_THRESHOLD=0.15

# 分段结果缓存
QUIZ_SEGMENT_CACHE_ENABLED=true

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_DIR=./data/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
