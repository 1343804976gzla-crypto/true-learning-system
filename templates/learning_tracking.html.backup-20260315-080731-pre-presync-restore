// ========== Period Controls ==========
function setPeriod(p) {
    currentPeriod = p;
    currentDateStr = null;
    ['day','week','month','all'].forEach(function(k) {
        var btn = document.getElementById('tab-' + k);
        if (k === p) { btn.className = 'px-4 py-2 rounded text-sm font-medium bg-blue-500 text-white'; }
        else { btn.className = 'px-4 py-2 rounded text-sm font-medium transition hover:bg-gray-100 text-gray-600'; }
    });
    var showNav = (p !== 'all');
    document.getElementById('btnPrevDate').classList.toggle('hidden', !showNav);
    document.getElementById('btnNextDate').classList.toggle('hidden', !showNav);
    loadAllData();
}

function navigateDate(dir) {
    var base = currentDateStr ? new Date(currentDateStr) : new Date();
    if (currentPeriod === 'day') base.setDate(base.getDate() + dir);
    else if (currentPeriod === 'week') base.setDate(base.getDate() + dir * 7);
    else if (currentPeriod === 'month') base.setMonth(base.getMonth() + dir);
    currentDateStr = base.toISOString().slice(0, 10);
    loadAllData();
}

function updateDateLabel(data) {
    var label = '';
    if (data.start_date && data.end_date) {
        label = data.start_date.slice(0, 10) + ' ~ ' + data.end_date.slice(0, 10);
    } else { label = '\u5168\u90e8\u6570\u636e'; }
    document.getElementById('dateRangeLabel').textContent = label;
}

// ========== Main Data Load ==========
async function loadAllData() {
    try {
        var url = '/api/tracking/stats?period=' + currentPeriod;
        if (currentDateStr) url += '&date_str=' + currentDateStr;
        statsData = await safeFetch(url, {}, '操作失败');
        updateDateLabel(statsData);
        renderSummary(statsData);
        renderTrendChart(statsData.daily_trend);
        renderTypeRadar(statsData.type_distribution);
        renderConfidenceScatter(statsData.knowledge_points);
        renderDifficultyBar(statsData.difficulty_distribution);
        renderGroupedSessions(statsData.sessions);
        loadKnowledgeTree();
    } catch (e) { console.error('loadAllData error:', e); }
}

// ========== Layer 1: North Star Metrics ==========
function renderSummary(data) {
    var s = data.summary;
    document.getElementById('totalQuestions').textContent = s.total_questions;
    var dur = s.total_duration;
    document.getElementById('totalDuration').textContent = dur >= 3600 ? Math.round(dur / 360) / 10 + 'h' : Math.round(dur / 60) + 'min';
    document.getElementById('avgAccuracy').textContent = s.avg_accuracy + '%';
    document.getElementById('totalSessions').textContent = s.total_sessions;

    var wowEl = document.getElementById('wowDelta');
    if (data.wow_delta && data.wow_delta.delta !== null) {
        var d = data.wow_delta.delta;
        var arrow = d > 0 ? '\u2191' : (d < 0 ? '\u2193' : '\u2192');
        var color = d > 0 ? 'text-green-600' : (d < 0 ? 'text-red-600' : 'text-gray-400');
        wowEl.className = 'text-xs mt-1 font-medium ' + color;
        wowEl.textContent = '\u5468\u73af\u6bd4 ' + arrow + ' ' + Math.abs(d) + '%';
    } else { wowEl.textContent = ''; }

    if (data.weakest_area) {
        document.getElementById('weakestName').textContent = data.weakest_area.name;
        document.getElementById('weakestName').title = data.weakest_area.name;
        document.getElementById('weakestAccuracy').textContent = '\u6b63\u786e\u7387 ' + data.weakest_area.accuracy + '% (' + data.weakest_area.correct + '/' + data.weakest_area.total + ')';
    } else {
        document.getElementById('weakestName').textContent = '\u6682\u65e0';
        document.getElementById('weakestAccuracy').textContent = '\u505a\u9898\u22653\u624d\u4f1a\u663e\u793a';
    }
}

function formatInsightDate(dateStr) {
    if (!dateStr) return '--';
    return dateStr.slice(5).replace('-', '/');
}

function formatInsightRange(startDate, endDate) {
    return formatInsightDate(startDate) + ' - ' + formatInsightDate(endDate);
}

function getInsightAvgTop(avgValue, maxValue) {
    if (!maxValue || maxValue <= 0) return 58;
    var ratio = avgValue / maxValue;
    ratio = Math.max(0.1, Math.min(0.92, ratio));
    return 100 - ratio * 100;
}

