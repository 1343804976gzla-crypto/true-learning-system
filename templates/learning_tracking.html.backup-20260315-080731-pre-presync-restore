        quadrantPanel.innerHTML = '';
        var quadrantHeader = document.createElement('div');
        quadrantHeader.className = 'tracking-shell-header';
        quadrantHeader.appendChild(buildTrackingSectionCopy('\u77e5\u8bc6\u70b9\u8bca\u65ad\u8c61\u9650', 'Quadrant', 'Insight', '\u628a\u9ad8\u81ea\u4fe1\u548c\u9ad8\u6b63\u786e\u7387\u7684\u8fb9\u754c\u6e05\u6670\u62c6\u5f00\u3002'));
        var quadrantBody = document.createElement('div');
        quadrantBody.className = 'tracking-shell-body';
        quadrantBody.appendChild(quadrantList);
        quadrantPanel.appendChild(quadrantHeader);
        quadrantPanel.appendChild(quadrantBody);

        diffPanel.className = 'wa-fold-card tracking-panel-card tracking-difficulty-panel';
        diffPanel.setAttribute('data-open', 'true');
        diffPanel.innerHTML = '';
        var diffHeader = document.createElement('div');
        diffHeader.className = 'tracking-shell-header';
        diffHeader.appendChild(buildTrackingSectionCopy('\u96be\u5ea6\u901a\u8fc7\u7387', 'Difficulty', 'Pass Rate', '\u6bd4\u8f83\u57fa\u7840\u3001\u63d0\u9ad8\u3001\u96be\u9898\u4e09\u4e2a\u5c42\u7ea7\u7684\u547d\u4e2d\u7387\u3002'));
        var diffBody = document.createElement('div');
        diffBody.className = 'tracking-shell-body';
        var diffShell = document.createElement('div');
        diffShell.className = 'tracking-difficulty-shell';
        diffShell.appendChild(diffMount);
        diffBody.appendChild(diffShell);
        diffPanel.appendChild(diffHeader);
        diffPanel.appendChild(diffBody);
    }

    var treeSection = document.getElementById('knowledgeTreeSection');
    if (treeSection) {
        treeSection.className = 'wa-fold-card wa-fold-card--chapters tracking-tree-shell';
        treeSection.setAttribute('data-open', 'true');
        var treeContent = document.getElementById('knowledgeTreeContent');
        var treeMount = document.getElementById('knowledgeTree');
        var treeToggle = document.getElementById('treeToggleBtn');
        var treeExport = treeSection.querySelector('button[onclick="exportKnowledgeTreeMd()"]');
        treeSection.innerHTML = '';
        var treeHeader = document.createElement('div');
        treeHeader.className = 'tracking-shell-header';
        treeHeader.appendChild(buildTrackingSectionCopy('\u5927\u7eb2\u77e5\u8bc6\u70b9\u8ffd\u8e2a', 'Knowledge Tree', 'Outline', '\u6309\u4e66\u672c\u3001\u7ae0\u8282\u548c\u77e5\u8bc6\u70b9\u5c55\u5f00\u638c\u63e1\u60c5\u51b5\u3002'));
        var treeActions = document.createElement('div');
        treeActions.className = 'tracking-shell-header__actions';
        if (treeExport) { treeExport.className = 'tracking-inline-btn'; treeActions.appendChild(treeExport); }
        if (treeToggle) { treeToggle.className = 'tracking-inline-btn'; treeActions.appendChild(treeToggle); }
        treeHeader.appendChild(treeActions);
        treeContent.className = 'tracking-shell-body';
        treeContent.innerHTML = '';
        treeContent.appendChild(treeMount);
        treeSection.appendChild(treeHeader);
        treeSection.appendChild(treeContent);
    }

    var sessionsList = document.getElementById('sessionsList');
    if (sessionsList) {
        var sessionsSection = sessionsList.parentElement;
        sessionsSection.className = 'wa-fold-card tracking-sessions-shell';
        sessionsSection.setAttribute('data-open', 'true');
        var expandAllBtn = document.getElementById('expandAllBtn');
        sessionsSection.innerHTML = '';
        var sessionsHeader = document.createElement('div');
        sessionsHeader.className = 'tracking-shell-header';
        sessionsHeader.appendChild(buildTrackingSectionCopy('\u5b66\u4e60\u8bb0\u5f55', 'Sessions', 'History', '\u6c47\u603b\u6574\u5377\u6d4b\u8bd5\u548c\u7ec6\u8282\u7ec3\u4e60\uff0c\u652f\u6301\u5c55\u5f00\u67e5\u770b\u7edf\u8ba1\u3002'));
        var sessionActions = document.createElement('div');
        sessionActions.className = 'tracking-shell-header__actions';
        if (expandAllBtn) {
            expandAllBtn.className = 'tracking-inline-btn';
            sessionActions.appendChild(expandAllBtn);
        }
        sessionsHeader.appendChild(sessionActions);
        var sessionsBody = document.createElement('div');
        sessionsBody.className = 'tracking-shell-body';
        sessionsList.className = 'tracking-session-stack';
        sessionsBody.appendChild(sessionsList);
        sessionsSection.appendChild(sessionsHeader);
        sessionsSection.appendChild(sessionsBody);
    }

    var detailModal = document.getElementById('detailModal');
    if (detailModal) {
        detailModal.className = 'hidden fixed inset-0 tracking-modal-backdrop z-50 overflow-y-auto';
        var modalCard = document.getElementById('modalContent').parentElement;
        modalCard.className = 'inline-block w-full max-w-4xl my-8 text-left align-middle wa-fold-card tracking-modal-card';
        modalCard.setAttribute('data-open', 'true');
        var modalHeader = document.getElementById('modalTitle').parentElement;
        modalHeader.className = 'tracking-shell-header';
        document.getElementById('modalTitle').className = 'wa-fold-card__title';
        var modalActions = modalHeader.querySelector('div');
        if (modalActions) {
            modalActions.className = 'tracking-shell-header__actions';
            var modalButtons = modalActions.querySelectorAll('button');
            if (modalButtons[0]) modalButtons[0].className = 'tracking-inline-btn';
            if (modalButtons[1]) modalButtons[1].className = 'tracking-inline-btn';
            if (modalButtons[2]) modalButtons[2].className = 'tracking-icon-btn';
        }
        document.getElementById('modalContent').className = 'tracking-modal-content';
    }
}

async function showDetail(sessionId) {
    currentSessionId = sessionId;
    try {
        var data = await safeFetch('/api/tracking/session/' + sessionId, {}, '\u8bf7\u6c42\u5931\u8d25');
        document.getElementById('modalTitle').textContent = data.title || '\u5b66\u4e60\u8be6\u60c5';

        var total = Number(data.correct_count || 0) + Number(data.wrong_count || 0);
        var html = '<section class="tracking-modal-section">' +
            '<div class="tracking-modal-section__title">\u57fa\u672c\u4fe1\u606f</div>' +
            '<div class="tracking-modal-grid">' +
                buildTrackingModalStat('\u7c7b\u578b', data.session_type === 'exam' ? '\u6574\u5377\u6d4b\u8bd5' : '\u7ec6\u8282\u7ec3\u4e60') +
                buildTrackingModalStat('\u5f97\u5206', (data.score || 0) + ' \u5206') +
                buildTrackingModalStat('\u6b63\u786e\u7387', (data.accuracy || 0) + '%') +
                buildTrackingModalStat('\u7528\u65f6', formatTrackingDuration(data.duration_seconds)) +
            '</div>' +
        '</section>';

        if (data.sure_count || data.unsure_count || data.no_count) {
            html += '<section class="tracking-modal-section">' +
                '<div class="tracking-modal-section__title">\u81ea\u4fe1\u5ea6\u5206\u5e03</div>' +
                '<div class="tracking-modal-grid">' +
                    buildTrackingModalStat('\u786e\u5b9a', String(data.sure_count || 0)) +
                    buildTrackingModalStat('\u6a21\u7cca', String(data.unsure_count || 0)) +
                    buildTrackingModalStat('\u4e0d\u4f1a', String(data.no_count || 0)) +
                    buildTrackingModalStat('\u9898\u91cf', String(total || 0)) +
                '</div>' +
            '</section>';
        }

        if (data.questions && data.questions.length) {
            html += '<section class="tracking-modal-section">' +
                '<div class="tracking-modal-section__title">\u9898\u76ee\u8be6\u60c5</div>' +
                '<div class="tracking-module__stack">';
            data.questions.forEach(function(q, i) {
                var confMap = { sure: '\u786e\u5b9a', unsure: '\u6a21\u7cca', no: '\u4e0d\u4f1a' };
                html += '<article class="tracking-question-card ' + (q.is_correct ? 'tracking-question-card--correct' : 'tracking-question-card--wrong') + '">' +
                    '<div class="tracking-module__row-head">' +
                        '<div class="tracking-module__name">\u7b2c ' + (i + 1) + ' \u9898 [' + escapeHtml(q.type || 'A1') + ']</div>' +
                        '<div class="tracking-module__meta">' +
                            '<span class="' + getTrackingPillClass(q.is_correct ? 'green' : 'red') + '">' + (q.is_correct ? '\u6b63\u786e' : '\u9519\u8bef') + '</span>' +
                            '<span class="' + getTrackingPillClass(q.confidence === 'sure' ? 'green' : (q.confidence === 'unsure' ? 'amber' : (q.confidence === 'no' ? 'red' : 'slate'))) + '">' + escapeHtml(confMap[q.confidence] || '\u672a\u6807\u8bb0') + '</span>' +
                        '</div>' +
                    '</div>' +
                    '<div class="tracking-module__hint" style="margin-top:0.7rem;">' + escapeHtml(q.question || '') + '</div>' +
                    '<div class="tracking-module__stack" style="margin-top:0.7rem;gap:0.45rem;">' +
                        '<div class="tracking-session-copy">\u4f60\u7684\u7b54\u6848\uff1a' + escapeHtml(q.user_answer || '\u2014') + '</div>' +
                        '<div class="tracking-session-copy">\u6b63\u786e\u7b54\u6848\uff1a' + escapeHtml(q.correct_answer || '\u2014') + '</div>' +
                        (q.key_point ? '<div class="tracking-session-copy">\u77e5\u8bc6\u70b9\uff1a' + escapeHtml(q.key_point) + '</div>' : '') +
                    '</div>' +
                '</article>';
            });
            html += '</div></section>';
        } else {
            html += '<section class="tracking-modal-section">' +
                '<div class="tracking-modal-section__title">\u9898\u76ee\u8be6\u60c5</div>' +
                buildTrackingEmptyState('\u6682\u65e0\u53ef\u5c55\u793a\u7684\u9898\u76ee\u5185\u5bb9', true) +
            '</section>';
        }

        document.getElementById('modalContent').innerHTML = html;
        document.getElementById('detailModal').classList.remove('hidden');
    } catch (error) {
        alert('\u52a0\u8f7d\u8be6\u60c5\u5931\u8d25');
    }
}

// Click outside modal to close
document.getElementById('detailModal').addEventListener('click', function(e) {
    if (e.target === this) { closeModal(); }
});
</script>
