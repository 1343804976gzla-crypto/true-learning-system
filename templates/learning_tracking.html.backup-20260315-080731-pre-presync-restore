function renderGroupedSessions(sessions) {
    var container = document.getElementById('sessionsList');
    if (!container) return;
    container.innerHTML = '';
    if (!sessions || sessions.length === 0) {
        container.innerHTML = buildTrackingEmptyState('\u6682\u65e0\u5b66\u4e60\u8bb0\u5f55', false);
        return;
    }

    var groups = [];
    var examMap = {};
    sessions.forEach(function(s) {
        if (s.session_type === 'exam') {
            var g = { exam: s, details: [] };
            groups.push(g);
            if (s.chapter_id) examMap[s.chapter_id + '_' + (s.started_at || '').slice(0, 10)] = g;
        }
    });

    var orphanDetails = [];
    sessions.forEach(function(s) {
        if (s.session_type !== 'detail_practice') return;
        var key = (s.chapter_id || '') + '_' + (s.started_at || '').slice(0, 10);
        if (examMap[key]) examMap[key].details.push(s);
        else orphanDetails.push(s);
    });

    if (orphanDetails.length) groups.push({ exam: null, details: orphanDetails });
    groups.forEach(function(group, gi) {
        if (group.exam) renderExamCard(container, group, gi);
        else renderStandaloneDetails(container, group);
    });
}

