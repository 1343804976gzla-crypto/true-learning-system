function buildExpandedPanel(group, gi) {
    var agg = aggregateKnowledgePoints(group);
    var kpMap = agg.kpMap;
    var kpKeys = Object.keys(kpMap).sort(function(a, b) { return kpMap[b].wrong - kpMap[a].wrong; });

    var moduleA = '<section class="tracking-module tracking-module--full">' +
        '<div class="tracking-module__header">' +
            '<div><div class="tracking-module__title">\u77e5\u8bc6\u70b9\u638c\u63e1\u660e\u7ec6</div><div class="tracking-module__subtitle">\u4ece\u6b63\u786e\u7387\u3001\u4e3b\u89c2\u4fe1\u5fc3\u548c\u5ba2\u89c2\u8282\u594f\u4e09\u4e2a\u7ef4\u5ea6\u8bfb\u8fd9\u6b21\u7ec3\u4e60\u3002</div></div>' +
            '<span class="' + getTrackingPillClass('slate') + '">' + kpKeys.length + ' KP</span>' +
        '</div>';

    if (!kpKeys.length) {
        moduleA += buildTrackingEmptyState('\u8fd9\u6b21\u4f1a\u8bdd\u8fd8\u6ca1\u6709\u77e5\u8bc6\u70b9\u660e\u7ec6', true);
    } else {
        moduleA += '<div class="tracking-module__stack">';
        kpKeys.forEach(function(kp) {
            var v = kpMap[kp];
            var acc = v.total > 0 ? Math.round(v.correct / v.total * 100) : 0;
            var confCounts = { sure: 0, unsure: 0, no: 0 };
            v.confidences.forEach(function(c) { if (confCounts[c] !== undefined) confCounts[c]++; });
            var dominantConf = '';
            if (v.confidences.length) {
                dominantConf = 'sure';
                if (confCounts.unsure > confCounts[dominantConf]) dominantConf = 'unsure';
                if (confCounts.no > confCounts[dominantConf]) dominantConf = 'no';
            }
            var avgTime = v.times.length ? v.times.reduce(function(a, b) { return a + b; }, 0) / v.times.length : 0;
            var obj = getObjectiveAssessment(avgTime, v.changes);
            var confTone = dominantConf === 'sure' ? 'green' : (dominantConf === 'unsure' ? 'amber' : (dominantConf === 'no' ? 'red' : 'slate'));
            moduleA += '<div class="tracking-module__row">' +
                '<div class="tracking-module__row-head">' +
                    '<div class="tracking-module__name" title="' + escapeHtml(kp) + '">' + escapeHtml(kp) + '</div>' +
                    '<div class="tracking-module__meta">' +
                        '<span class="' + getTrackingPillClass(getTrackingBand(acc)) + '">\u6b63\u786e\u7387 ' + acc + '%</span>' +
                        (dominantConf ? '<span class="' + getTrackingPillClass(confTone) + '">\u4e3b\u89c2 ' + escapeHtml(getConfidenceLabel(dominantConf)) + '</span>' : '') +
                        '<span class="' + getTrackingPillClass(toneFromUtilityClass(obj.color)) + '">\u5ba2\u89c2 ' + escapeHtml(obj.label) + '</span>' +
                    '</div>' +
                '</div>' +
                '<div class="tracking-module__meter">' +
                    '<div class="tracking-meter"><span class="' + getTrackingFillClass(acc) + '" style="width:' + acc + '%"></span></div>' +
                    '<span class="tracking-module__count">' + v.correct + '/' + v.total + '</span>' +
                '</div>' +
                '<div class="tracking-module__hint">' + escapeHtml(obj.desc) + '</div>' +
            '</div>';
        });
        moduleA += '</div>';
    }
    moduleA += '</section>';

    var moduleB = buildModuleB(kpMap, kpKeys, agg.allQuestions, gi);
    var examId = group.exam ? group.exam.id : null;
    var detailIds = group.details.map(function(d) { return d.id; });
    var allIds = examId ? [examId].concat(detailIds) : detailIds;
    var cta = '<section class="tracking-module tracking-module--full">' +
        '<div class="tracking-module__header">' +
            '<div><div class="tracking-module__title">\u6c89\u6d78\u5f0f\u590d\u76d8</div><div class="tracking-module__subtitle">\u6253\u5f00\u5b8c\u6574\u9898\u76ee\u3001\u89e3\u6790\u548c\u5bfc\u51fa\uff0c\u7ee7\u7eed\u5f80\u4e0b\u94bb\u3002</div></div>' +
            '<span class="' + getTrackingPillClass('blue') + '">Deep Review</span>' +
        '</div>' +
        '<div class="tracking-cta-wrap">' +
            '<a href="/session-review?ids=' + encodeURIComponent(allIds.join(',')) + '" target="_blank" class="tracking-cta-link">\u8fdb\u5165\u6c89\u6d78\u5f0f\u590d\u76d8</a>' +
