function inferTrackingButtonTone(button) {
    var cls = String(button.className || '').toLowerCase();
    var text = String(button.textContent || '').trim().toLowerCase();
    var combined = (cls + ' ' + text + ' ' + String(button.id || '').toLowerCase() + ' ' + String(button.getAttribute('onclick') || '').toLowerCase());
    if (combined.indexOf('tracking-period-btn--active') > -1 || /refresh|\u5237\u65b0|loadalldata/.test(combined)) return 'blue';
    if (/export|\u5bfc\u51fa/.test(combined)) return 'emerald';
    if (/review|\u590d\u76d8/.test(combined)) return 'violet';
    if (/prev|next|\u4e0a\u4e00|\u4e0b\u4e00|\u5c55\u5f00|\u6536\u8d77|\u5173\u95ed|toggle|expandall/.test(combined)) return 'slate';
    if (/danger|delete|\u5220\u9664/.test(combined)) return 'red';
    return 'frost';
}

function inferTrackingButtonShape(button) {
    var cls = String(button.className || '').toLowerCase();
    var text = String(button.textContent || '').trim();
    if (cls.indexOf('tracking-icon-btn') > -1 || text === '\u00d7' || text === 'x' || cls.indexOf('text-2xl') > -1) return 'icon';
    return 'pill';
}

function syncTrackingButton(button) {
    if (!button || button.tagName !== 'BUTTON') return;
    if (button.dataset.glassIgnore === 'true') return;
    button.dataset.glassButton = 'true';
    button.dataset.glassTone = inferTrackingButtonTone(button);
    button.dataset.glassShape = inferTrackingButtonShape(button);
}

function getTrackingBand(value) {
    value = Number(value || 0);
    if (value >= 80) return 'green';
    if (value >= 60) return 'amber';
    return 'red';
}

function getTrackingTextClass(value) {
    var band = getTrackingBand(value);
    if (band === 'green') return 'text-green-600';
    if (band === 'amber') return 'text-yellow-600';
    return 'text-red-600';
}

function getTrackingFillClass(value) {
    return 'tracking-fill tracking-fill--' + getTrackingBand(value);
}

function getTrackingPillClass(tone) {
    return 'tracking-data-pill tracking-data-pill--' + (tone || 'slate');
}

function toneFromUtilityClass(colorClass) {
    var cls = String(colorClass || '').toLowerCase();
    if (cls.indexOf('green') > -1) return 'green';
    if (cls.indexOf('blue') > -1) return 'blue';
    if (cls.indexOf('yellow') > -1 || cls.indexOf('amber') > -1) return 'amber';
    if (cls.indexOf('red') > -1) return 'red';
    return 'slate';
}

function formatTrackingDuration(seconds) {
    var total = Number(seconds || 0);
    if (total <= 0) return '\u2014';
    if (total >= 3600) return (Math.round(total / 360) / 10) + 'h';
    return Math.max(1, Math.round(total / 60)) + '\u5206\u949f';
}

function formatTrackingDateTime(dateStr) {
    if (!dateStr) return '\u2014';
    try {
        return new Date(dateStr).toLocaleString('zh-CN');
    } catch (error) {
        return dateStr;
    }
}

