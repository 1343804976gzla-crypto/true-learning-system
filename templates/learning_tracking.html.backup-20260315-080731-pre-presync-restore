    if (cls.indexOf('tracking-icon-btn') > -1 || text === '×' || text === '✕' || cls.indexOf('text-2xl') > -1) return 'icon';
    return 'pill';
} */

function syncTrackingButton(button) {
    if (!button || button.tagName !== 'BUTTON') return;
    button.dataset.glassButton = 'true';
    button.dataset.glassTone = inferTrackingButtonTone(button);
    button.dataset.glassShape = inferTrackingButtonShape(button);
}

function enhanceTrackingButtons(scope) {
    var root = scope && scope.querySelectorAll ? scope : document;
    root.querySelectorAll('.learning-tracking-page button').forEach(syncTrackingButton);
    if (scope && scope.matches && scope.matches('.learning-tracking-page button')) {
        syncTrackingButton(scope);
    }
}

function observeTrackingButtons() {
    var root = document.querySelector('.learning-tracking-page');
    if (!root || trackingButtonObserver) return;
    trackingButtonObserver = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.type === 'attributes' && mutation.target && mutation.target.tagName === 'BUTTON') {
                syncTrackingButton(mutation.target);
                return;
            }
            mutation.addedNodes.forEach(function(node) {
                if (!node || node.nodeType !== 1) return;
                if (node.tagName === 'BUTTON') syncTrackingButton(node);
                if (node.querySelectorAll) enhanceTrackingButtons(node);
            });
        });
    });
    trackingButtonObserver.observe(root, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['class', 'disabled']
    });
}

