{% extends "base.html" %}

{% block title %}学习轨迹 - 战略指挥舱{% endblock %}

{% block extra_css %}
<style>
    .insight-card {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background:
            radial-gradient(circle at top right, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0) 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.94));
        padding: 1.2rem;
        box-shadow:
            0 24px 60px rgba(15, 23, 42, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }

    .insight-card::before {
        content: "";
        position: absolute;
        inset: auto -2rem -3.5rem auto;
        width: 9rem;
        height: 9rem;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.18), rgba(59, 130, 246, 0));
        pointer-events: none;
    }

    .insight-card--amber::before {
        background: radial-gradient(circle, rgba(245, 158, 11, 0.18), rgba(245, 158, 11, 0));
    }

    .insight-card--blue {
        --insight-bar-start: #4f8dfd;
        --insight-bar-end: #97beff;
        --insight-dot: #4f8dfd;
        --insight-pill-bg: rgba(59, 130, 246, 0.12);
        --insight-pill-color: #1d4ed8;
        --insight-avg-bg: #0f172a;
        --insight-avg-text: #ffffff;
    }

    .insight-card--amber {
        --insight-bar-start: #fb7185;
        --insight-bar-end: #fda4af;
        --insight-dot: #fb7185;
        --insight-pill-bg: rgba(245, 158, 11, 0.14);
        --insight-pill-color: #b45309;
        --insight-avg-bg: #422006;
        --insight-avg-text: #fff7ed;
    }

    .insight-card__header {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.65rem;
    }

    .insight-card__eyebrow {
        display: inline-block;
        margin-bottom: 0.35rem;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #94a3b8;
    }

    .insight-card__headline {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
    }

    .insight-card__title {
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
    }

    .insight-card__pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 1.75rem;
        border-radius: 999px;
        padding: 0.25rem 0.65rem;
        font-size: 0.72rem;
        font-weight: 700;
        background: var(--insight-pill-bg);
        color: var(--insight-pill-color);
    }

    .insight-card__action {
        flex-shrink: 0;
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.88);
        color: #0f172a;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 0.42rem 0.8rem;
        transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
    }

    .insight-card__action:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 1);
        border-color: rgba(59, 130, 246, 0.28);
    }

    .insight-card__range {
        display: flex;
        align-items: flex-end;
        gap: 0.35rem;
        margin-bottom: 0.25rem;
        position: relative;
        z-index: 1;
    }

    .insight-card__value {
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 0.95;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: #0f172a;
    }

    .insight-card__unit {
        font-size: 1.1rem;
        font-weight: 400;
        color: #94a3b8;
        margin-bottom: 0.28rem;
    }

    .insight-card__meta {
        position: relative;
        z-index: 1;
        font-size: 0.78rem;
        color: #64748b;
    }

    .insight-card__chart-shell {
        position: relative;
        height: 10.75rem;
        margin: 1.15rem 0 1rem;
    }

    .insight-card__avg-line {
        position: absolute;
        left: 0;
        right: 0;
        top: var(--insight-avg-top, 45%);
        height: 1.5px;
        background: rgba(148, 163, 184, 0.28);
        z-index: 1;
    }

    .insight-card__avg-label {
        position: absolute;
        right: 0;
        top: calc(var(--insight-avg-top, 45%) - 1.75rem);
        z-index: 2;
        border-radius: 999px;
        padding: 0.22rem 0.55rem;
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        background: var(--insight-avg-bg);
        color: var(--insight-avg-text);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
    }

    .insight-card__chart {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(var(--insight-bar-count, 7), minmax(0, 1fr));
        align-items: end;
        gap: 0.45rem;
        height: 100%;
        padding: 0 0.2rem;
    }

    .insight-card__bar-slot {
        display: flex;
        height: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        gap: 0.45rem;
        min-width: 0;
    }

    .insight-card__bar-value {
        font-size: 0.66rem;
        font-weight: 700;
        color: #64748b;
        line-height: 1;
    }

    .insight-card__bar-stage {
        position: relative;
        display: flex;
        width: 100%;
        flex: 1;
        align-items: flex-end;
        justify-content: center;
        padding-top: 0.4rem;
    }

    .insight-card__bar {
        position: relative;
        width: min(22px, 100%);
        min-height: 10px;
        border-radius: 999px;
        background: linear-gradient(to bottom, var(--insight-bar-start), var(--insight-bar-end));
        box-shadow:
            0 14px 26px rgba(15, 23, 42, 0.14),
            inset 0 -1px 0 rgba(255, 255, 255, 0.32);
        transition: transform 0.24s ease, filter 0.24s ease;
    }

    .insight-card__bar:hover {
        transform: translateY(-2px) scale(1.04);
        filter: saturate(1.08);
    }

    .insight-card__dot {
        position: absolute;
        left: 50%;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #ffffff;
        border: 1.5px solid var(--insight-dot);
        transform: translateX(-50%);
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.12);
    }

    .insight-card__dot--top {
        top: -4px;
    }

    .insight-card__dot--bottom {
        bottom: -4px;
    }

    .insight-card__day {
        font-size: 0.66rem;
        font-weight: 700;
        color: #94a3b8;
        letter-spacing: 0.04em;
    }

    .insight-card__readings {
        position: relative;
        z-index: 1;
        border-top: 1px solid rgba(226, 232, 240, 0.9);
        padding-top: 0.8rem;
    }

    .insight-card__reading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.45rem 0;
        border-bottom: 1px solid rgba(241, 245, 249, 0.9);
        font-size: 0.82rem;
    }

    .insight-card__reading:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .insight-card__reading-time {
        color: #94a3b8;
    }

    .insight-card__reading-value {
        font-weight: 800;
        color: #0f172a;
        text-align: right;
    }

    .insight-card__empty {
        font-size: 0.9rem;
        color: #94a3b8;
        padding: 1rem 0;
    }

    .tracking-side-panel {
        border-radius: 22px;
        border: 1px solid rgba(226, 232, 240, 0.92);
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
    }

    .tracking-analysis-grid {
        align-items: stretch;
    }

    .tracking-radar-panel,
    .tracking-quadrant-panel,
    .tracking-difficulty-panel {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
    }

    .tracking-radar-shell {
        display: flex;
        flex: 1 1 auto;
        min-height: 0;
        align-items: center;
        justify-content: center;
        padding: 0.35rem 0 0.15rem;
    }

    .tracking-radar-box {
        position: relative;
        width: min(100%, 17rem);
        aspect-ratio: 1 / 1;
        margin: 0 auto;
    }

    .tracking-radar-box canvas {
        display: block;
        width: 100% !important;
        height: 100% !important;
    }

    .tracking-quadrant-list {
        flex: 1 1 auto;
        min-height: 0;
        width: 100%;
        padding-right: 0.15rem;
    }

    .tracking-difficulty-shell {
        flex: 1 1 auto;
        display: flex;
        min-height: 0;
        align-items: stretch;
    }

    .tracking-difficulty-shell > #diffInsightCard {
        width: 100%;
    }

    .tracking-difficulty-shell .insight-card {
        height: 100%;
    }

    .tracking-quadrant-card {
        --quadrant-accent: #64748b;
        --quadrant-ink: #0f172a;
        --quadrant-subtle: #475569;
        border-left: 4px solid var(--quadrant-accent);
        border-radius: 18px;
        padding: 0.85rem 0.95rem;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.92));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .tracking-quadrant-card--yellow {
        --quadrant-accent: #d97706;
        --quadrant-ink: #92400e;
        --quadrant-subtle: #b45309;
        background: linear-gradient(135deg, rgba(255, 247, 237, 0.98), rgba(254, 243, 199, 0.88));
    }

    .tracking-quadrant-card--red {
        --quadrant-accent: #dc2626;
        --quadrant-ink: #991b1b;
        --quadrant-subtle: #b91c1c;
        background: linear-gradient(135deg, rgba(254, 242, 242, 0.98), rgba(254, 226, 226, 0.88));
    }

    .tracking-quadrant-card--blue {
        --quadrant-accent: #2563eb;
        --quadrant-ink: #1d4ed8;
        --quadrant-subtle: #2563eb;
        background: linear-gradient(135deg, rgba(239, 246, 255, 0.98), rgba(219, 234, 254, 0.88));
    }

    .tracking-quadrant-card--green {
        --quadrant-accent: #16a34a;
        --quadrant-ink: #166534;
        --quadrant-subtle: #15803d;
        background: linear-gradient(135deg, rgba(240, 253, 244, 0.98), rgba(220, 252, 231, 0.88));
    }

    .tracking-quadrant-title {
        color: var(--quadrant-ink) !important;
    }

    .tracking-quadrant-desc {
        display: inline-block;
        margin-top: 0.18rem;
        color: var(--quadrant-subtle) !important;
    }

    .tracking-quadrant-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.65rem;
        padding: 0.32rem 0;
        border-top: 1px dashed rgba(148, 163, 184, 0.28);
    }

    .tracking-quadrant-item:first-of-type {
        margin-top: 0.25rem;
    }

    .tracking-quadrant-name {
        flex: 1;
        min-width: 0;
        color: #1f2937 !important;
    }

    .tracking-quadrant-meta {
        width: 2.75rem;
        flex-shrink: 0;
        text-align: right;
        font-size: 0.72rem;
        color: #6b7280 !important;
    }

    .tracking-quadrant-empty {
        color: #94a3b8 !important;
    }

    .dark .insight-card {
        border-color: rgba(148, 163, 184, 0.16);
        background:
            radial-gradient(circle at top right, rgba(59, 130, 246, 0.18), rgba(59, 130, 246, 0) 30%),
            linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.84));
        box-shadow:
            0 24px 60px rgba(2, 6, 23, 0.46),
            inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .dark .insight-card__title,
    .dark .insight-card__value,
    .dark .insight-card__reading-value {
        color: #f8fafc;
    }

    .dark .insight-card__action {
        border-color: rgba(148, 163, 184, 0.16);
        background: rgba(15, 23, 42, 0.54);
        color: #e2e8f0;
    }

    .dark .insight-card__action:hover {
        border-color: rgba(96, 165, 250, 0.28);
        background: rgba(30, 41, 59, 0.82);
    }

    .dark .insight-card__meta,
    .dark .insight-card__bar-value {
        color: #cbd5e1;
    }

    .dark .insight-card__day,
    .dark .insight-card__eyebrow,
    .dark .insight-card__reading-time {
        color: #94a3b8;
    }

    .dark .insight-card__avg-line {
        background: rgba(148, 163, 184, 0.22);
    }

    .dark .insight-card__readings {
        border-top-color: rgba(51, 65, 85, 0.9);
    }

    .dark .insight-card__reading {
        border-bottom-color: rgba(30, 41, 59, 0.9);
    }

    .dark .tracking-side-panel {
        border-color: rgba(51, 65, 85, 0.9);
        background: rgba(15, 23, 42, 0.78);
        box-shadow: 0 18px 40px rgba(2, 6, 23, 0.32);
    }

    .dark .tracking-quadrant-card {
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.04),
            0 14px 28px rgba(2, 6, 23, 0.18);
    }

    .dark .tracking-quadrant-card--yellow {
        --quadrant-accent: #fbbf24;
        --quadrant-ink: #fef3c7;
        --quadrant-subtle: #fde68a;
        background: linear-gradient(135deg, rgba(120, 53, 15, 0.34), rgba(69, 26, 3, 0.62));
    }

    .dark .tracking-quadrant-card--red {
        --quadrant-accent: #f87171;
        --quadrant-ink: #fecaca;
        --quadrant-subtle: #fda4af;
        background: linear-gradient(135deg, rgba(127, 29, 29, 0.34), rgba(69, 10, 10, 0.62));
    }

    .dark .tracking-quadrant-card--blue {
        --quadrant-accent: #60a5fa;
        --quadrant-ink: #dbeafe;
        --quadrant-subtle: #93c5fd;
        background: linear-gradient(135deg, rgba(30, 64, 175, 0.32), rgba(23, 37, 84, 0.62));
    }

    .dark .tracking-quadrant-card--green {
        --quadrant-accent: #4ade80;
        --quadrant-ink: #dcfce7;
        --quadrant-subtle: #86efac;
        background: linear-gradient(135deg, rgba(20, 83, 45, 0.34), rgba(5, 46, 22, 0.62));
    }

    .dark .tracking-quadrant-item {
        border-top-color: rgba(148, 163, 184, 0.18);
    }

    .dark .tracking-quadrant-name {
        color: #e2e8f0 !important;
    }

    .dark .tracking-quadrant-meta {
        color: #cbd5e1 !important;
    }

    .dark .tracking-quadrant-empty {
        color: #94a3b8 !important;
    }

    @media (min-width: 768px) {
        .tracking-radar-panel,
        .tracking-quadrant-panel,
        .tracking-difficulty-panel {
            height: 28rem;
        }
    }

    @media (max-width: 768px) {
        .insight-card {
            padding: 1rem;
            border-radius: 20px;
        }

        .insight-card__header {
            flex-direction: column;
            align-items: flex-start;
        }

        .insight-card__action {
            width: 100%;
        }

        .insight-card__chart-shell {
            height: 9.6rem;
        }

        .tracking-radar-shell {
            min-height: 15rem;
            padding-top: 0.1rem;
        }

        .tracking-radar-box {
            width: min(100%, 14.5rem);
        }
    }
    .learning-tracking-page {
        --wa-glass-top: rgba(255, 255, 255, 0.88);
        --wa-glass-bottom: rgba(248, 250, 252, 0.74);
        --wa-glass-border: rgba(148, 163, 184, 0.24);
        --wa-glass-text: #0f172a;
        --wa-glass-shadow: rgba(15, 23, 42, 0.12);
        --wa-glass-highlight: rgba(255, 255, 255, 0.7);
        --wa-glass-sheen: rgba(255, 255, 255, 0.34);
        --wa-glass-bloom: rgba(255, 255, 255, 0.24);
        --wa-glass-edge: rgba(255, 255, 255, 0.12);
        --wa-glass-radius: 999px;
    }

    .learning-tracking-page .tracking-hero {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .learning-tracking-page .tracking-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.65rem;
        font-size: 0.82rem;
        color: #94a3b8;
    }

    .learning-tracking-page .tracking-breadcrumb a {
        color: inherit;
        transition: color 0.2s ease;
    }

    .learning-tracking-page .tracking-breadcrumb a:hover {
        color: #2563eb;
    }

    .learning-tracking-page .tracking-hero__title {
        font-size: clamp(1.75rem, 2vw + 1.2rem, 2.35rem);
        line-height: 1.1;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: #0f172a;
    }

    .learning-tracking-page .tracking-hero__subtitle {
        margin-top: 0.45rem;
        max-width: 42rem;
        font-size: 0.95rem;
        color: #64748b;
    }

    .learning-tracking-page .tracking-hero__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
    }

    .tracking-shell-header {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.3rem 1.35rem 1rem;
    }

    .tracking-shell-header__content {
        min-width: 0;
    }

    .tracking-shell-header__actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.65rem;
        flex-wrap: wrap;
    }

    .tracking-shell-body {
        position: relative;
        z-index: 1;
        padding: 0 1.35rem 1.35rem;
    }

    .tracking-control-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .tracking-period-group,
    .tracking-date-nav {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-wrap: wrap;
    }

    .tracking-action-btn,
    .tracking-period-btn,
    .tracking-nav-btn,
    .tracking-inline-btn,
    .tracking-icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        background: transparent;
        border: 0;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
    }

    .tracking-action-btn {
        min-height: 2.9rem;
        padding: 0.8rem 1.15rem;
        font-size: 0.84rem;
    }

    .tracking-period-btn,
    .tracking-nav-btn {
        min-height: 2.7rem;
        padding: 0.72rem 1rem;
        font-size: 0.82rem;
    }

    .tracking-inline-btn {
        min-height: 2.5rem;
        padding: 0.62rem 0.95rem;
        font-size: 0.75rem;
    }

    .tracking-icon-btn {
        font-size: 1.55rem;
        padding: 0.65rem;
    }

    .tracking-period-btn--active {
        font-weight: 800;
    }

    #dateRangeLabel {
        display: inline-flex;
        align-items: center;
        min-height: 2.6rem;
        padding: 0 0.25rem;
        font-size: 0.84rem;
        font-weight: 700;
        color: #64748b;
    }

    .learning-tracking-page button[data-glass-button="true"] {
        position: relative;
        isolation: isolate;
        overflow: hidden;
        border-radius: var(--wa-glass-radius) !important;
        border: 1px solid var(--wa-glass-border) !important;
        background-color: transparent !important;
        background-image:
            radial-gradient(140% 120% at 50% -18%, rgba(255, 255, 255, 0.2), transparent 48%),
            linear-gradient(180deg, var(--wa-glass-top), var(--wa-glass-bottom)) !important;
        color: var(--wa-glass-text) !important;
        box-shadow:
            0 14px 30px var(--wa-glass-shadow),
            inset 0 1px 0 var(--wa-glass-highlight),
            inset 0 -1px 0 rgba(255, 255, 255, 0.18),
            inset 0 0 0 1px rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(14px) saturate(160%);
        -webkit-backdrop-filter: blur(14px) saturate(160%);
        transition:
            transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
            box-shadow 0.28s cubic-bezier(0.22, 1, 0.36, 1),
            border-color 0.28s ease,
            filter 0.28s ease,
            background-image 0.28s ease;
    }

    .learning-tracking-page button[data-glass-button="true"]::before {
        content: "";
        position: absolute;
        inset: 1px;
        z-index: -2;
        border-radius: calc(var(--wa-glass-radius) - 1px);
        background:
            radial-gradient(135% 85% at 50% -10%, var(--wa-glass-sheen), transparent 52%),
            radial-gradient(88% 130% at 16% 20%, rgba(255, 255, 255, 0.22), transparent 42%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04) 36%, rgba(255, 255, 255, 0.1));
        opacity: 0.96;
        pointer-events: none;
    }

    .learning-tracking-page button[data-glass-button="true"]::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: inherit;
        background:
            radial-gradient(130% 96% at 50% -24%, var(--wa-glass-bloom), transparent 54%),
            radial-gradient(46% 86% at 86% 78%, rgba(255, 255, 255, 0.14), transparent 68%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.03) 28%, var(--wa-glass-edge) 62%, rgba(255, 255, 255, 0) 100%);
        opacity: 0.78;
        transform: scale(1);
        pointer-events: none;
        transition: transform 0.42s ease, opacity 0.3s ease, filter 0.3s ease;
    }

    .learning-tracking-page button[data-glass-button="true"]:hover:not(:disabled) {
        transform: translateY(-1px) scale(1.01);
        box-shadow:
