}

function buildModuleB(kpMap, kpKeys, allQuestions, gi) {
    var quadrants = { danger: [], gap: [], lucky: [], mastered: [] };
    kpKeys.forEach(function(kp) {
        var v = kpMap[kp];
        if (!v || !v.total) return;
        var acc = v.correct / v.total * 100;
        var subjScore = 0;
        if (v.confidences.length > 0) {
            var confSum = 0;
            v.confidences.forEach(function(c) {
                if (c === 'sure') confSum += 100;
                else if (c === 'unsure') confSum += 50;
            });
            subjScore = confSum / v.confidences.length;
        }
        var avgTime = v.times.length ? v.times.reduce(function(a, b) { return a + b; }, 0) / v.times.length : 30;
        var objScore = Math.max(0, Math.min(100, 100 - (avgTime - 10) * 2 - v.changes * 20));
        var confidence = subjScore * 0.6 + objScore * 0.4;
        var item = { name: kp, acc: Math.round(acc), correct: v.correct, total: v.total };
        if (acc >= 50 && confidence >= 50) quadrants.mastered.push(item);
        else if (acc < 50 && confidence >= 50) quadrants.danger.push(item);
        else if (acc < 50 && confidence < 50) quadrants.gap.push(item);
        else quadrants.lucky.push(item);
    });

    var quadrantCards = '';
    [
        { key: 'danger', label: '\u81f4\u547d\u76f2\u533a', desc: '\u4ee5\u4e3a\u4f1a\uff0c\u5b9e\u9645\u5f88\u5361', tone: 'yellow' },
        { key: 'gap', label: '\u77e5\u8bc6\u7f3a\u53e3', desc: '\u81ea\u4fe1\u548c\u7ed3\u679c\u90fd\u8f83\u5f31', tone: 'red' },
        { key: 'lucky', label: '\u4fa5\u5e78\u533a', desc: '\u7ed3\u679c\u8fd8\u53ef\u4ee5\uff0c\u4f46\u7a33\u5b9a\u6027\u4e0d\u8db3', tone: 'blue' },
        { key: 'mastered', label: '\u638c\u63e1\u7a33\u5b9a', desc: '\u77e5\u8bc6\u70b9\u72b6\u6001\u826f\u597d', tone: 'green' }
    ].forEach(function(entry) {
        var list = quadrants[entry.key];
        if (!list.length) return;
        list.sort(function(a, b) { return a.acc - b.acc; });
        quadrantCards += '<div class="tracking-quadrant-card tracking-quadrant-card--' + entry.tone + '">' +
            '<div class="tracking-quadrant-title">' + escapeHtml(entry.label) + '<span class="tracking-quadrant-desc">' + escapeHtml(entry.desc) + '</span></div>';
        list.forEach(function(item) {
            quadrantCards += '<div class="tracking-quadrant-item">' +
                '<span class="tracking-quadrant-name truncate" title="' + escapeHtml(item.name) + '">' + escapeHtml(item.name) + '</span>' +
                '<span class="' + getTrackingTextClass(item.acc) + ' font-bold">' + item.acc + '%</span>' +
                '<span class="tracking-quadrant-meta">' + item.correct + '/' + item.total + '</span>' +
            '</div>';
        });
        quadrantCards += '</div>';
    });

    var masteryRows = '';
    kpKeys.forEach(function(kp) {
        var v = kpMap[kp];
        var acc = v.total > 0 ? Math.round(v.correct / v.total * 100) : 0;
        masteryRows += '<div class="tracking-module__row">' +
            '<div class="tracking-module__row-head">' +
                '<div class="tracking-module__name" title="' + escapeHtml(kp) + '">' + escapeHtml(kp) + '</div>' +
                '<div class="tracking-module__meta"><span class="' + getTrackingPillClass(getTrackingBand(acc)) + '">' + acc + '%</span></div>' +
            '</div>' +
            '<div class="tracking-module__meter">' +
                '<div class="tracking-mini-meter"><span class="' + getTrackingFillClass(acc) + '" style="width:' + acc + '%"></span></div>' +
                '<span class="tracking-module__count">' + v.correct + '/' + v.total + '</span>' +
            '</div>' +
        '</div>';
    });

    return '<div class="tracking-module-grid">' +
        '<section class="tracking-module">' +
            '<div class="tracking-module__header">' +
                '<div><div class="tracking-module__title">\u77e5\u8bc6\u76f2\u533a\u56db\u8c61\u9650</div><div class="tracking-module__subtitle">\u7528\u7ec3\u4e60\u7ed3\u679c\u548c\u4f5c\u7b54\u72b6\u6001\u628a\u98ce\u9669\u70b9\u62c6\u5f00\u770b\u3002</div></div>' +
                '<span class="' + getTrackingPillClass('slate') + '">Risk Map</span>' +
            '</div>' +
            '<div class="tracking-module__list">' + (quadrantCards || buildTrackingEmptyState('\u6682\u65e0\u53ef\u7528\u4e8e\u8c61\u9650\u5206\u6790\u7684\u9898\u76ee', true)) + '</div>' +
        '</section>' +
        '<section class="tracking-module">' +
            '<div class="tracking-module__header">' +
                '<div><div class="tracking-module__title">\u677f\u5757\u638c\u63e1\u5ea6</div><div class="tracking-module__subtitle">\u628a\u77e5\u8bc6\u70b9\u6309\u51c6\u786e\u7387\u91cd\u6392\uff0c\u5f88\u5bb9\u6613\u627e\u5230\u5148\u8865\u7684\u4e00\u5757\u3002</div></div>' +
                '<span class="' + getTrackingPillClass('violet') + '">Scoreboard</span>' +
            '</div>' +
            '<div class="tracking-module__stack">' + (masteryRows || buildTrackingEmptyState('\u6682\u65e0\u53ef\u7528\u4e8e\u638c\u63e1\u5ea6\u5206\u6790\u7684\u6570\u636e', true)) + '</div>' +
        '</section>' +
    '</div>';
}

