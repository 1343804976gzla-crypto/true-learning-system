function inferTrackingButtonTone(button) {
    var cls = String(button.className || '');
    var text = String(button.textContent || '').trim();
    var combined = (cls + ' ' + text + ' ' + (button.id || '')).toLowerCase();
    if (combined.indexOf('tracking-period-btn--active') > -1 || text.indexOf('刷新') > -1) return 'blue';
    if (text.indexOf('导出') > -1) return 'emerald';
    if (text.indexOf('展开') > -1 || text.indexOf('收起') > -1 || text.indexOf('上一') > -1 || text.indexOf('下一') > -1) return 'slate';
    if (text.indexOf('关闭') > -1 || text === '×' || text === '&times;') return 'slate';
    return 'frost';
}

