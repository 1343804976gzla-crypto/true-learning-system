    var counts = dates.map(function(dk) { return dailyTrend[dk] ? Number(dailyTrend[dk].questions || 0) : 0; });
    var accs = dates.map(function(dk) {
        if (!dailyTrend[dk] || Number(dailyTrend[dk].questions || 0) === 0) return null;
        return Math.round(Number(dailyTrend[dk].correct || 0) / Number(dailyTrend[dk].questions || 1) * 100);
    });

    var maxCount = counts.reduce(function(maxValue, item) { return Math.max(maxValue, Number(item || 0)); }, 0);
    var minCount = counts.reduce(function(minValue, item) { return Math.min(minValue, Number(item || 0)); }, counts.length ? Number(counts[0] || 0) : 0);
    var avgCount = counts.length ? counts.reduce(function(sum, item) { return sum + Number(item || 0); }, 0) / counts.length : 0;
    var validAccs = accs.filter(function(item) { return item !== null && item !== undefined; });
    var avgAcc = validAccs.length
        ? validAccs.reduce(function(sum, item) { return sum + Number(item || 0); }, 0) / validAccs.length
        : 0;

    var bars = dates.map(function(dateKey, index) {
        var questions = Number(counts[index] || 0);
        var acc = accs[index];
        return {
            label: formatInsightDate(dateKey),
            value: questions,
            displayValue: String(questions),
            topDot: acc !== null && acc >= 85,
            bottomDot: acc !== null && acc > 0 && acc < 60,
            tooltip: formatInsightDate(dateKey) + '\uff1a' + questions + '\u9898' + (acc !== null ? ('\uff0c\u6b63\u786e\u7387 ' + acc + '%') : '')
        };
    });

    var readings = dates.slice(-3).reverse().map(function(dateKey) {
        var questions = dailyTrend[dateKey] ? Number(dailyTrend[dateKey].questions || 0) : 0;
        var acc = dailyTrend[dateKey] && questions > 0
            ? Math.round(Number(dailyTrend[dateKey].correct || 0) / questions * 100)
            : 0;
        return {
            label: '\u6700\u8fd1 ' + formatInsightDate(dateKey),
            value: questions + ' \u9898 \u00b7 \u6b63\u786e\u7387 ' + acc + '%'
        };
    });

    container.innerHTML = buildInsightCard({
        variantClass: 'insight-card--rose',
        eyebrow: 'Learning Trend',
        title: '\u8fd114\u5929\u5b66\u4e60\u8d8b\u52bf',
        pillText: '\u65e5\u5747 ' + avgCount.toFixed(1) + ' \u9898',
        actionLabel: '\u67e5\u770b\u8bb0\u5f55',
        actionOnClick: 'scrollToSessions()',
        rangeValue: minCount + '-' + maxCount,
        rangeUnit: '\u9898',
        metaText: formatInsightRange(dates[0], dates[dates.length - 1]) + ' \u00b7 \u5e73\u5747\u6b63\u786e\u7387 ' + avgAcc.toFixed(1) + '%',
        avgValue: avgCount,
        maxValue: Math.max(maxCount, avgCount, 1),
        avgLabel: '\u5747\u503c ' + avgCount.toFixed(1),
        bars: bars,
        readings: readings
    });
}

function renderConfidenceScatter(kpData) {
    var container = document.getElementById('confidenceQuadrantList');
    if (!container) return;

    var quadrants = {
        danger: { label: '\u81f4\u547d\u76f2\u533a', desc: '\u81ea\u4fe1\u9ad8\u4f46\u6b63\u786e\u7387\u4f4e', tone: 'yellow', items: [] },
        gap: { label: '\u77e5\u8bc6\u7f3a\u53e3', desc: '\u81ea\u4fe1\u4f4e\u4e14\u6b63\u786e\u7387\u4f4e', tone: 'red', items: [] },
        lucky: { label: '\u4fa5\u5e78\u533a', desc: '\u81ea\u4fe1\u4f4e\u4f46\u6b63\u786e\u7387\u9ad8', tone: 'blue', items: [] },
        mastered: { label: '\u5df2\u638c\u63e1', desc: '\u81ea\u4fe1\u9ad8\u4e14\u6b63\u786e\u7387\u9ad8', tone: 'green', items: [] }
    };

    Object.keys(kpData || {}).forEach(function(kp) {
        var v = kpData[kp];
        if (!v || Number(v.total || 0) === 0) return;
        var acc = Math.round(Number(v.correct || 0) / Math.max(Number(v.total || 1), 1) * 100);
        var conf = v.has_confidence_data !== false && v.avg_confidence != null ? Math.round(Number(v.avg_confidence || 0) * 100) : 0;
        var item = { name: kp, acc: acc, conf: conf, total: Number(v.total || 0), correct: Number(v.correct || 0) };
        if (acc >= 50 && conf >= 50) quadrants.mastered.items.push(item);
        else if (acc < 50 && conf >= 50) quadrants.danger.items.push(item);
        else if (acc < 50 && conf < 50) quadrants.gap.items.push(item);
        else quadrants.lucky.items.push(item);
    });

    var order = ['danger', 'gap', 'lucky', 'mastered'];
    var html = '';
    order.forEach(function(key) {
        quadrants[key].items.sort(function(a, b) { return a.acc - b.acc; });
        if (!quadrants[key].items.length) return;
        var q = quadrants[key];
        html += '<div class="tracking-quadrant-card tracking-quadrant-card--' + q.tone + '">' +
            '<div class="tracking-quadrant-title">' + escapeHtml(q.label) +
                '<span class="tracking-quadrant-desc">' + escapeHtml(q.desc) + '</span>' +
            '</div>';
        q.items.forEach(function(item) {
            html += '<div class="tracking-quadrant-item">' +
                '<span class="tracking-quadrant-name truncate" title="' + escapeHtml(item.name) + '">' + escapeHtml(item.name) + '</span>' +
                '<span class="' + getTrackingTextClass(item.acc) + ' font-bold">' + item.acc + '%</span>' +
                '<span class="tracking-quadrant-meta">' + item.correct + '/' + item.total + '</span>' +
            '</div>';
        });
        html += '</div>';
    });

    container.innerHTML = html || buildTrackingEmptyState('\u6682\u65e0\u77e5\u8bc6\u70b9\u8c61\u9650\u6570\u636e', true);
}

