    function generateKnowledgeAnalysis(result) {
        const container = document.getElementById('knowledgeList');
        const knowledgeMap = {};

        result.details.forEach(function(d, i) {
            const keyPoint = d.key_point || '鑰冪偣' + (i + 1);
            if (!knowledgeMap[keyPoint]) {
                knowledgeMap[keyPoint] = { correct: 0, wrong: 0, difficulty: d.difficulty };
            }
            if (d.is_correct) knowledgeMap[keyPoint].correct++;
            else knowledgeMap[keyPoint].wrong++;
        });

        const knowledgeList = Object.entries(knowledgeMap).map(function([point, data]) {
            return {
                point: point,
                correct: data.correct,
                wrong: data.wrong,
                difficulty: data.difficulty,
                status: data.wrong === 0 ? 'good' : (data.correct > data.wrong ? 'partial' : 'weak')
            };
        });

        let html = '';

        const weakPoints = knowledgeList.filter(function(k) { return k.status === 'weak' || k.status === 'partial'; });
        if (weakPoints.length > 0) {
            html += '<div class="mb-4"><h4 class="font-medium text-red-600 mb-2">鉂?闇€瑕佸姞寮虹殑鐭ヨ瘑鐐癸細</h4><div class="space-y-2">';
            weakPoints.forEach(function(k) {
                html += '<div class="flex justify-between items-center p-2 bg-red-50 rounded"><span class="text-sm">' + k.point + '</span><span class="text-xs text-red-600">' + k.wrong + '閿?' + (k.correct + k.wrong) + '棰?/span></div>';
            });
            html += '</div></div>';
        }

        const goodPoints = knowledgeList.filter(function(k) { return k.status === 'good'; });
        if (goodPoints.length > 0) {
            html += '<div><h4 class="font-medium text-green-600 mb-2">鉁?宸叉帉鎻＄殑鐭ヨ瘑鐐癸細</h4><div class="flex flex-wrap gap-2">';
            goodPoints.forEach(function(k) {
                html += '<span class="px-2 py-1 bg-green-100 text-green-700 rounded text-sm">' + k.point + '</span>';
            });
            html += '</div></div>';
        }

        if (knowledgeList.length === 0) {
            html = '<div class="text-gray-500 text-sm">鏆傛棤鐭ヨ瘑鐐规暟鎹?/div>';
        }

        container.innerHTML = html;
    }

