    function selectOption(idx, opt, isMultiple) {
        if (isMultiple) {
            if (!userAnswers[idx]) userAnswers[idx] = [];
            const checkboxes = document.querySelectorAll('input[name="q' + idx + '"]');
            const selected = [];
            checkboxes.forEach(function(cb) {
                if (cb.checked) {
                    selected.push(cb.value);
                    const label = cb.closest('label');
                    if (label) label.classList.add('border-blue-500', 'bg-blue-50');
                } else {
                    const label = cb.closest('label');
                    if (label) label.classList.remove('border-blue-500', 'bg-blue-50');
                }
            });
            userAnswers[idx] = selected.sort().join('');
        } else {
            userAnswers[idx] = opt;
            document.querySelectorAll('[data-idx="' + idx + '"]').forEach(function(label) {
                if (label.dataset.opt === opt) {
                    label.classList.add('border-blue-500', 'bg-blue-50');
                } else {
                    label.classList.remove('border-blue-500', 'bg-blue-50');
                }
            });
        }

        const statusEl = document.getElementById('status-' + idx);
        if (statusEl) {
            statusEl.textContent = '鉁?;
            statusEl.className = 'text-green-500 text-xl font-bold';
        }

        updateProgress();
        
        // 璁板綍绛旈鍒板涔犺建杩?        recordQuestionAnswer(idx);
    }

