{% block extra_js %}
<script>
    console.log('JavaScript 寮€濮嬪姞杞?);

    const chapterId = '{{ chapter_id }}';
    console.log('chapterId:', chapterId);

    let uploadedContent = '';
    let numQuestions = 10;
    let examId = null;
    let questions = [];
    let userAnswers = {};
    let userConfidence = {};
    let timerInterval = null;
    let currentQuestion = 0;
    let trackingSessionId = null;  // 瀛︿範杞ㄨ抗浼氳瘽ID
    let chaptersGrouped = {};      // 绔犺妭鐩綍缂撳瓨
    let pendingExamData = null;    // 寰呯‘璁ょ殑璇曞嵎鏁版嵁
    let confirmedChapterId = chapterId; // 纭鍚庣殑绔犺妭ID
    function buildMaskedExplanationHtml(explanation, isCorrect, confidence, revealId, keyPoint) {
        const text = explanation || '暂无解析';
        const keyPointHtml = '<div class="mt-2 text-sm text-blue-600"><span class="font-medium">核心考点：</span>' + (keyPoint || '未标注') + '</div>';

        if (!explanation || (isCorrect && confidence === 'sure')) {
            return '<div class="bg-gray-50 p-4 rounded-lg"><div class="font-medium text-gray-700 mb-2">解析</div>' +
                '<p class="text-gray-600 text-sm">' + text + '</p>' +
                keyPointHtml + '</div>';
        }

        return '<div class="bg-gray-50 p-4 rounded-lg"><div class="font-medium text-gray-700 mb-2">解析</div>' +
            '<button type="button" onclick="revealMaskedExplanation(\'' + revealId + '\', this)" ' +
            'class="w-full text-left bg-amber-50 border border-amber-300 text-amber-700 px-3 py-2 rounded-lg text-sm hover:bg-amber-100 transition">' +
            '这题做错了，先自己想一下，点击查看解析</button>' +
            '<p id="' + revealId + '" class="text-gray-600 text-sm mt-3 hidden">' + text + '</p>' +
            keyPointHtml + '</div>';
    }

    function revealMaskedExplanation(revealId, triggerBtn) {
        const explanationEl = document.getElementById(revealId);
        if (explanationEl) explanationEl.classList.remove('hidden');
        if (triggerBtn) triggerBtn.classList.add('hidden');
    }

    // 椤甸潰鍔犺浇鏃惰幏鍙栫珷鑺傜洰褰?    (async function loadChapterCatalog() {
        try {
            const r = await fetch('/api/chapters/grouped');
            chaptersGrouped = await r.json();
            console.log('绔犺妭鐩綍宸插姞杞? 绉戠洰鏁?', Object.keys(chaptersGrouped).length);
        } catch(e) {
            console.error('鍔犺浇绔犺妭鐩綍澶辫触:', e);
        }
    })();

    // 瀛楃璁℃暟
    document.getElementById('contentInput').addEventListener('input', function() {
        document.getElementById('charCount').textContent = this.value.length + ' 瀛楃';
    });

    // 涓嬩竴姝ユ寜閽?    document.getElementById('nextBtn').addEventListener('click', function() {
        const content = document.getElementById('contentInput').value.trim();
        if (content.length < 100) {
            alert('璇疯嚦灏戣緭鍏?00瀛楃殑鍐呭锛屽綋鍓嶅彧鏈?' + content.length + ' 瀛?);
            return;
        }
        uploadedContent = content;
        document.getElementById('step1').classList.add('hidden');
        document.getElementById('step2').classList.remove('hidden');
    });

    // 涓婁竴姝ユ寜閽?    document.getElementById('prevBtn').addEventListener('click', function() {
        document.getElementById('step2').classList.add('hidden');
        document.getElementById('step1').classList.remove('hidden');
    });

    // 鐢熸垚璇曞嵎
    document.getElementById('generateBtn').addEventListener('click', async function() {
        const selected = document.querySelector('input[name="questionCount"]:checked');
        numQuestions = parseInt(selected ? selected.value : 10);

        document.getElementById('step2').classList.add('hidden');
        document.getElementById('loadingState').classList.remove('hidden');

        try {
            const response = await fetch('/api/quiz/batch/generate/' + chapterId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    uploaded_content: uploadedContent,
                    num_questions: numQuestions
                })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.detail || '鐢熸垚澶辫触');
            }

            const data = await response.json();
            console.log('鐢熸垚鎴愬姛, 棰樼洰鏁伴噺:', data.questions.length);

            examId = data.exam_id;
            questions = data.questions;
