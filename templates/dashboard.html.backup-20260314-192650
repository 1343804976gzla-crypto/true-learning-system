{% extends "base.html" %}

{% block title %}True Learning System - 医学考研学习系统{% endblock %}

{% block content %}
<!-- ===== HERO SECTION WITH GLOWY WAVES ===== -->
<div class="relative -mx-6 -mt-8 mb-12 overflow-hidden" style="height: 480px;">
    <canvas id="waveCanvas" class="absolute inset-0 w-full h-full"></canvas>

    <!-- Decorative blurs -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute left-1/2 top-0 h-[420px] w-[420px] -translate-x-1/2 rounded-full opacity-[0.035] dark:opacity-[0.06] blur-[140px]" style="background: currentColor;"></div>
        <div class="absolute bottom-0 right-0 h-[300px] w-[300px] rounded-full opacity-[0.025] dark:opacity-[0.05] blur-[120px]" style="background: currentColor;"></div>
    </div>

    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 z-10">
        <div class="inline-flex items-center gap-2 rounded-full border border-gray-300/40 dark:border-gray-700/60 bg-white/60 dark:bg-gray-900/70 px-4 py-2 text-xs font-semibold uppercase tracking-widest text-gray-600 dark:text-gray-300 mb-6 backdrop-blur-sm">
            <svg class="w-4 h-4" style="color:#8B7355;" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            AI 驱动学习系统
        </div>
        <h1 class="font-serif text-4xl md:text-6xl font-bold mb-4 text-gray-900 dark:text-white">
            True Learning
        </h1>
        <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300 max-w-2xl">
            沉浸式医学考研学习体验，实时响应每一次交互
        </p>
    </div>
</div>

<script>
(function() {
    const canvas = document.getElementById('waveCanvas');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animationId;
    let time = 0;
    const mouse = { x: 0, y: 0 };
    const targetMouse = { x: 0, y: 0 };

    // Theme-aware colors
    function getThemeColors() {
        const isDark = document.documentElement.classList.contains('dark');

        if (isDark) {
            return {
                bgTop: 'rgba(26, 26, 26, 1)',
                bgBottom: 'rgba(26, 26, 26, 0.95)',
                waves: [
                    { offset: 0, amp: 70, freq: 0.003, color: 'rgba(139, 115, 85, 0.6)', opacity: 0.45 },
                    { offset: Math.PI/2, amp: 90, freq: 0.0026, color: 'rgba(196, 180, 154, 0.5)', opacity: 0.35 },
                    { offset: Math.PI, amp: 60, freq: 0.0034, color: 'rgba(229, 229, 229, 0.4)', opacity: 0.3 },
                    { offset: Math.PI*1.5, amp: 80, freq: 0.0022, color: 'rgba(255, 255, 255, 0.25)', opacity: 0.25 },
                    { offset: Math.PI*2, amp: 55, freq: 0.004, color: 'rgba(255, 255, 255, 0.2)', opacity: 0.2 }
                ]
            };
        } else {
            return {
                bgTop: 'rgba(254, 251, 246, 1)',
                bgBottom: 'rgba(254, 251, 246, 0.95)',
                waves: [
                    { offset: 0, amp: 70, freq: 0.003, color: 'rgba(139, 115, 85, 0.8)', opacity: 0.45 },
                    { offset: Math.PI/2, amp: 90, freq: 0.0026, color: 'rgba(196, 180, 154, 0.7)', opacity: 0.35 },
                    { offset: Math.PI, amp: 60, freq: 0.0034, color: 'rgba(45, 45, 45, 0.65)', opacity: 0.3 },
                    { offset: Math.PI*1.5, amp: 80, freq: 0.0022, color: 'rgba(85, 85, 85, 0.5)', opacity: 0.25 },
                    { offset: Math.PI*2, amp: 55, freq: 0.004, color: 'rgba(100, 100, 100, 0.4)', opacity: 0.2 }
                ]
            };
        }
    }

    let colors = getThemeColors();

    // Watch for theme changes
    const observer = new MutationObserver(() => {
        colors = getThemeColors();
    });
    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
    });

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mouseInfluence = prefersReducedMotion ? 10 : 70;
    const influenceRadius = prefersReducedMotion ? 160 : 320;
    const smoothing = prefersReducedMotion ? 0.04 : 0.1;

    function resizeCanvas() {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
    }

    function recenterMouse() {
        const center = { x: canvas.width / 2, y: canvas.height / 2 };
        mouse.x = center.x;
        mouse.y = center.y;
        targetMouse.x = center.x;
        targetMouse.y = center.y;
    }

    function handleResize() {
        resizeCanvas();
        recenterMouse();
    }

    function handleMouseMove(e) {
        const rect = canvas.getBoundingClientRect();
        targetMouse.x = e.clientX - rect.left;
        targetMouse.y = e.clientY - rect.top;
    }

    function handleMouseLeave() {
        recenterMouse();
    }

    resizeCanvas();
    recenterMouse();

    window.addEventListener('resize', handleResize);
    canvas.addEventListener('mousemove', handleMouseMove);
    canvas.addEventListener('mouseleave', handleMouseLeave);

    function drawWave(wave) {
        ctx.save();
        ctx.beginPath();

        for (let x = 0; x <= canvas.width; x += 4) {
            const dx = x - mouse.x;
            const dy = canvas.height / 2 - mouse.y;
            const distance = Math.sqrt(dx * dx + dy * dy);
            const influence = Math.max(0, 1 - distance / influenceRadius);
            const mouseEffect = influence * mouseInfluence * Math.sin(time * 0.001 + x * 0.01 + wave.offset);

            const y = canvas.height / 2 +
                Math.sin(x * wave.freq + time * 0.002 + wave.offset) * wave.amp +
                Math.sin(x * wave.freq * 0.4 + time * 0.003) * (wave.amp * 0.45) +
                mouseEffect;

            if (x === 0) {
                ctx.moveTo(x, y);
            } else {
                ctx.lineTo(x, y);
            }
        }

        ctx.lineWidth = 2.5;
        ctx.strokeStyle = wave.color;
        ctx.globalAlpha = wave.opacity;
        ctx.shadowBlur = 35;
        ctx.shadowColor = wave.color;
        ctx.stroke();
        ctx.restore();
    }

    function animate() {
        time += 1;

        mouse.x += (targetMouse.x - mouse.x) * smoothing;
        mouse.y += (targetMouse.y - mouse.y) * smoothing;

        const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
        gradient.addColorStop(0, colors.bgTop);
        gradient.addColorStop(1, colors.bgBottom);

        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.globalAlpha = 1;
        ctx.shadowBlur = 0;

        colors.waves.forEach(drawWave);

        animationId = requestAnimationFrame(animate);
    }

    animationId = requestAnimationFrame(animate);

    // Cleanup
    window.addEventListener('beforeunload', () => {
        window.removeEventListener('resize', handleResize);
        canvas.removeEventListener('mousemove', handleMouseMove);
        canvas.removeEventListener('mouseleave', handleMouseLeave);
        cancelAnimationFrame(animationId);
        observer.disconnect();
    });
})();
</script>

