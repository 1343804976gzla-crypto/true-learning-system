{% extends "base.html" %}

{% block title %}True Learning System - 医学考研学习系统{% endblock %}

{% block content %}
<!-- ===== HERO SECTION ===== -->
<div class="relative -mx-6 -mt-8 mb-12 overflow-hidden" style="height: 380px;">
    <img src="https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?w=1400&q=80"
         alt="hero" class="w-full h-full object-cover">
    <div class="dark:hidden absolute inset-0" style="background: linear-gradient(to bottom, transparent 30%, #FEFBF6 95%);"></div>
    <div class="hidden dark:block absolute inset-0" style="background: linear-gradient(to bottom, transparent 30%, #1A1A1A 95%);"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-white drop-shadow-lg mb-3">True Learning</h1>
        <p class="text-white/90 text-lg drop-shadow-md">AI驱动的医学考研学习系统</p>
    </div>
</div>

<!-- ===== FEATURED: 整卷测验入口 ===== -->
<a href="/quiz/batch/0" class="block mag-card mb-14 group">
    <div class="md:flex">
        <div class="md:w-1/2 mag-card-img" style="aspect-ratio:3/2;">
            <img src="https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?w=800&q=80"
                 alt="整卷测验" class="w-full h-full object-cover">
        </div>
        <div class="md:w-1/2 p-8 flex flex-col justify-center">
            <span class="text-xs uppercase tracking-widest text-gray-400 mb-2">Featured</span>
            <h2 class="font-serif text-2xl md:text-3xl font-bold mb-3">整卷测验</h2>
            <p class="text-gray-500 mb-6 leading-relaxed">粘贴学习内容，一次性生成整套试卷。涵盖知识点辨析、题目变式与难度梯度，高效检验学习成果。</p>
            <span class="btn-primary self-start group-hover:bg-gray-700 transition-colors">开始学习 &rarr;</span>
        </div>
    </div>
</a>

<!-- ===== 学习工具 ===== -->
<h2 class="section-title">学习工具</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-14">
    <a href="/quiz/batch/0" class="mag-card group">
        <div class="mag-card-img">
            <img src="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?w=600&q=80" alt="整卷测验">
        </div>
        <div class="p-5">
            <span class="text-xs text-gray-400">考试模式</span>
            <h3 class="font-serif text-lg font-semibold mt-1 mb-1">整卷测验</h3>
            <p class="text-sm text-gray-500">粘贴内容，生成完整试卷，模拟真实考试体验</p>
        </div>
    </a>
    <a href="/upload" class="mag-card group">
        <div class="mag-card-img">
            <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=600&q=80" alt="内容上传">
        </div>
        <div class="p-5">
            <span class="text-xs text-gray-400">资料管理</span>
            <h3 class="font-serif text-lg font-semibold mt-1 mb-1">内容上传</h3>
            <p class="text-sm text-gray-500">上传学习资料，AI自动解析并生成知识点</p>
        </div>
    </a>
</div>

<!-- ===== 复习巩固 ===== -->
<h2 class="section-title">复习巩固</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-14">
    <a href="/wrong-answers" class="mag-card group">
        <div class="mag-card-img">
            <img src="https://images.unsplash.com/photo-1517842645767-c639042777db?w=600&q=80" alt="错题本">
        </div>
        <div class="p-5">
            <span class="text-xs text-gray-400">错题管理</span>
            <h3 class="font-serif text-lg font-semibold mt-1 mb-1">错题本</h3>
            <p class="text-sm text-gray-500">复习错题，巩固薄弱环节，避免重复犯错</p>
        </div>
    </a>
    <a href="/knowledge-archive" class="mag-card group">
        <div class="mag-card-img">
            <img src="https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=600&q=80" alt="知识点归档">
        </div>
        <div class="p-5">
            <span class="text-xs text-gray-400">知识管理</span>
            <h3 class="font-serif text-lg font-semibold mt-1 mb-1">知识点归档</h3>
            <p class="text-sm text-gray-500">全局知识点掌握情况，一目了然</p>
        </div>
    </a>
</div>

<!-- ===== 数据分析 ===== -->
<h2 class="section-title">数据分析</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-14">
    <a href="/learning-tracking" class="mag-card group">
        <div class="mag-card-img">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80" alt="学习轨迹">
        </div>
        <div class="p-5">
            <span class="text-xs text-gray-400">数据追踪</span>
            <h3 class="font-serif text-lg font-semibold mt-1 mb-1">学习轨迹</h3>
            <p class="text-sm text-gray-500">查看学习数据与趋势分析，量化你的进步</p>
        </div>
    </a>
    <a href="/session-review" class="mag-card group">
        <div class="mag-card-img">
            <img src="https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?w=600&q=80" alt="沉浸式复盘">
        </div>
        <div class="p-5">
            <span class="text-xs text-gray-400">深度回顾</span>
            <h3 class="font-serif text-lg font-semibold mt-1 mb-1">沉浸式复盘</h3>
            <p class="text-sm text-gray-500">回顾每次学习过程，发现改进空间</p>
        </div>
    </a>
</div>

<!-- ===== 学习数据概览 ===== -->
<h2 class="section-title">学习数据</h2>
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-14">
    <div class="stat-card">
        <div class="text-xs text-gray-400 mb-1">学习次数</div>
        <div class="text-2xl font-bold text-blue-600">{{ stats.total_sessions }}</div>
    </div>
    <div class="stat-card">
        <div class="text-xs text-gray-400 mb-1">总做题数</div>
        <div class="text-2xl font-bold text-green-600">{{ stats.total_questions }}</div>
    </div>
    <div class="stat-card">
        <div class="text-xs text-gray-400 mb-1">平均正确率</div>
        <div class="text-2xl font-bold text-purple-600">{{ stats.avg_accuracy }}%</div>
    </div>
    <div class="stat-card">
        <div class="text-xs text-gray-400 mb-1">学习时长</div>
        <div class="text-2xl font-bold text-orange-600">
            {% if stats.total_duration >= 3600 %}
                {{ (stats.total_duration / 3600) | round(1) }}h
            {% else %}
                {{ (stats.total_duration / 60) | round(0) | int }}min
            {% endif %}
        </div>
    </div>
    <div class="stat-card">
        <div class="text-xs text-gray-400 mb-1">知识点数</div>
        <div class="text-2xl font-bold text-cyan-600">{{ stats.total_kps }}</div>
    </div>
    <div class="stat-card">
        <div class="text-xs text-gray-400 mb-1">薄弱知识点</div>
        <div class="text-2xl font-bold text-red-600">{{ stats.weak_kps }}</div>
        <div class="text-xs text-gray-400">正确率&lt;60%</div>
    </div>
</div>

<!-- ===== 最近学习 ===== -->
<h2 class="section-title">最近学习</h2>
<div class="mag-card mb-8">
    <div class="divide-y">
        {% if recent_sessions %}
            {% for s in recent_sessions %}
            <div class="px-6 py-4 hover:bg-gray-50 transition-colors">
                <div class="flex justify-between items-center mb-1">
                    <div class="flex items-center space-x-2">
                        {% if s.session_type == 'exam' %}
                            <span class="bg-blue-100 text-blue-800 px-2 py-0.5 rounded text-xs font-medium">整卷</span>
                        {% else %}
                            <span class="bg-purple-100 text-purple-800 px-2 py-0.5 rounded text-xs font-medium">细节</span>
                        {% endif %}
                        <span class="font-medium">{{ s.title }}</span>
                    </div>
                    <div class="flex items-center space-x-3 text-sm">
                        {% if s.accuracy is not none %}
                            {% set acc_pct = (s.accuracy * 100) | round(1) %}
                            <span class="font-bold {% if acc_pct >= 80 %}text-green-600{% elif acc_pct >= 60 %}text-yellow-600{% else %}text-red-600{% endif %}">
                                {{ acc_pct }}%
                            </span>
                        {% endif %}
                        <span class="text-gray-400 text-xs">
                            {{ s.started_at.strftime('%m-%d %H:%M') if s.started_at else '' }}
                        </span>
                    </div>
                </div>
                {% if s.accuracy is not none %}
                <div class="flex items-center mt-1">
                    <div class="flex-1 bg-gray-200 rounded-full h-1.5">
                        {% set acc_pct = (s.accuracy * 100) | round(1) %}
                        <div class="h-1.5 rounded-full transition-all {% if acc_pct >= 80 %}bg-green-500{% elif acc_pct >= 60 %}bg-yellow-500{% else %}bg-red-500{% endif %}" style="width:{{ acc_pct }}%"></div>
                    </div>
                    <span class="text-xs text-gray-400 ml-3">{{ s.correct_count or 0 }}/{{ (s.correct_count or 0) + (s.wrong_count or 0) }}</span>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        {% else %}
            <div class="px-6 py-10 text-center text-gray-400">
                还没有学习记录，开始一次整卷测验吧
            </div>
        {% endif %}
    </div>
    {% if recent_sessions %}
    <div class="px-6 py-3 border-t text-center">
        <a href="/learning-tracking" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">查看全部学习记录 &rarr;</a>
    </div>
    {% endif %}
</div>
{% endblock %}
