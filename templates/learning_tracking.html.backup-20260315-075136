    }
}

function toggleAllCards() {
    allExamsExpanded = !allExamsExpanded;
    var btn = document.getElementById('expandAllBtn');
    btn.textContent = allExamsExpanded ? '\u6536\u8d77\u5168\u90e8 \u25b2' : '\u5c55\u5f00\u5168\u90e8 \u25bc';

    document.querySelectorAll('[id^="card-panel-"]').forEach(function(el) {
        el.classList.toggle('hidden', !allExamsExpanded);
    });
    document.querySelectorAll('.card-toggle-hint').forEach(function(hint) {
        hint.textContent = allExamsExpanded ? '\u70b9\u51fb\u6536\u8d77 \u25b2' : '\u70b9\u51fb\u5c55\u5f00\u77e5\u8bc6\u70b9\u8be6\u60c5\u4e0e\u7edf\u8ba1 \u25bc';
    });
}

// ========== Detail Modal ==========
async function showDetail(sessionId) {
    currentSessionId = sessionId;
    try {
        var data = await safeFetch('/api/tracking/session/' + sessionId, {}, '请求失败');

        document.getElementById('modalTitle').textContent = data.title || '\u5b66\u4e60\u8be6\u60c5';

        var html = '';

        var durMin = data.duration_seconds ? Math.floor(data.duration_seconds / 60) : 0;
        var durSec = data.duration_seconds ? (data.duration_seconds % 60) : 0;
        html += '<div class="mb-6">' +
            '<h4 class="font-bold mb-2">\u57fa\u672c\u4fe1\u606f</h4>' +
            '<div class="grid grid-cols-2 gap-4 text-sm bg-gray-50 p-4 rounded">' +
            '<div><span class="text-gray-500">\u7c7b\u578b\uff1a</span>' + (data.session_type === 'exam' ? '\u6574\u5377\u6d4b\u8bd5' : '\u7ec6\u8282\u7ec3\u4e60') + '</div>' +
            '<div><span class="text-gray-500">\u5f97\u5206\uff1a</span><span class="font-bold text-blue-600">' + (data.score || 0) + ' \u5206</span></div>' +
            '<div><span class="text-gray-500">\u6b63\u786e\u7387\uff1a</span><span class="font-bold ' + ((data.accuracy || 0) >= 60 ? 'text-green-600' : 'text-red-600') + '">' + (data.accuracy || 0) + '%</span></div>' +
            '<div><span class="text-gray-500">\u7528\u65f6\uff1a</span>' + durMin + '\u5206' + durSec + '\u79d2</div>' +
            '</div></div>';

        if (data.sure_count || data.unsure_count || data.no_count) {
            html += '<div class="mb-6">' +
                '<h4 class="font-bold mb-2">\u81ea\u4fe1\u5ea6\u5206\u5e03</h4>' +
                '<div class="grid grid-cols-3 gap-2">' +
                '<div class="text-center p-3 bg-green-50 rounded"><div class="text-2xl font-bold text-green-600">' + (data.sure_count || 0) + '</div><div class="text-sm text-green-600">\u786e\u5b9a \u2713</div></div>' +
                '<div class="text-center p-3 bg-yellow-50 rounded"><div class="text-2xl font-bold text-yellow-600">' + (data.unsure_count || 0) + '</div><div class="text-sm text-yellow-600">\u6a21\u7cca ?</div></div>' +
                '<div class="text-center p-3 bg-red-50 rounded"><div class="text-2xl font-bold text-red-600">' + (data.no_count || 0) + '</div><div class="text-sm text-red-600">\u4e0d\u4f1a \u2717</div></div>' +
                '</div></div>';
        }

        if (data.questions && data.questions.length > 0) {
            html += '<div><h4 class="font-bold mb-2">\u9898\u76ee\u8be6\u60c5</h4><div class="space-y-3">';
            data.questions.forEach(function(q, i) {
                var status = q.is_correct ?
                    '<span class="text-green-600 font-bold">\u2713 \u6b63\u786e</span>' :
                    '<span class="text-red-600 font-bold">\u2717 \u9519\u8bef</span>';
                var confMap = {'sure': '\u2713 \u786e\u5b9a', 'unsure': '? \u6a21\u7cca', 'no': '\u2717 \u4e0d\u4f1a'};
                var conf = confMap[q.confidence] || '\u25cb \u672a\u6807\u8bb0';

                html += '<div class="p-4 bg-gray-50 rounded border-l-4 ' + (q.is_correct ? 'border-green-500' : 'border-red-500') + '">' +
                    '<div class="flex justify-between mb-2">' +
                    '<span class="font-medium">\u7b2c ' + (i + 1) + ' \u9898 [' + (q.type || 'A1') + '] ' + conf + '</span>' + status + '</div>' +
                    '<p class="text-sm mb-2">' + escapeHtml(q.question) + '</p>' +
                    '<div class="text-sm">' +
                    '<span class="' + (q.is_correct ? 'text-green-600' : 'text-red-600') + '">\u4f60\u7684\u7b54\u6848\uff1a' + escapeHtml(q.user_answer) + '</span>' +
                    ' | <span class="text-green-600">\u6b63\u786e\u7b54\u6848\uff1a' + q.correct_answer + '</span>' +
                    (q.key_point ? ' | \u77e5\u8bc6\u70b9\uff1a' + q.key_point : '') +
                    '</div></div>';
            });
            html += '</div></div>';
        }

        document.getElementById('modalContent').innerHTML = html;
        document.getElementById('detailModal').classList.remove('hidden');
    } catch (error) {
        alert('\u52a0\u8f7d\u8be6\u60c5\u5931\u8d25');
    }
}

function closeModal() {
    document.getElementById('detailModal').classList.add('hidden');
    currentSessionId = null;
}

// ========== Export Functions ==========
async function exportReport(format) {
    if (!currentSessionId) return;
    try {
        var data = await safeFetch('/api/tracking/export/' + currentSessionId + '?format=' + format, {}, '请求失败');
        navigator.clipboard.writeText(data.content).then(function() {
            alert('\u2713 \u62a5\u544a\u5df2\u590d\u5236\u5230\u526a\u8d34\u677f\uff01');
        });
    } catch (error) {
        alert('\u5bfc\u51fa\u5931\u8d25');
    }
}

async function exportMarkdown() {
    try {
        var url = '/api/tracking/export-markdown?period=' + currentPeriod;
        if (currentDateStr) url += '&date_str=' + currentDateStr;

        var data = await safeFetch(url, {}, '请求失败');
        navigator.clipboard.writeText(data.content).then(function() {
            alert('\u2713 Markdown\u62a5\u544a\u5df2\u590d\u5236\u5230\u526a\u8d34\u677f\uff01');
        });
    } catch (error) {
        alert('\u5bfc\u51fa\u5931\u8d25');
    }
}

// Click outside modal to close
document.getElementById('detailModal').addEventListener('click', function(e) {
    if (e.target === this) { closeModal(); }
});
</script>
{% endblock %}
